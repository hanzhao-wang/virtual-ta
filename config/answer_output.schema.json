{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "question": {
      "type": "string"
    },
    "direct_answer": {
      "type": "string"
    },
    "simple_example": {
      "type": "string"
    },
    "support_level": {
      "type": "string",
      "enum": [
        "local_materials",
        "local_plus_general_reasoning",
        "general_reasoning_only",
        "live_web_search"
      ]
    },
    "local_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "file_type": {
            "type": "string"
          },
          "locator_type": {
            "type": "string"
          },
          "locator": {
            "type": "string"
          },
          "excerpt": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "extraction_status": {
            "type": "string"
          }
        },
        "required": [
          "path",
          "title",
          "reason",
          "file_type",
          "locator_type",
          "locator",
          "excerpt",
          "confidence",
          "extraction_status"
        ]
      }
    },
    "web_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "domain",
          "reason"
        ]
      }
    },
    "notes": {
      "type": "string"
    },
    "follow_up_suggestions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "question",
    "direct_answer",
    "simple_example",
    "support_level",
    "local_sources",
    "web_sources",
    "notes",
    "follow_up_suggestions"
  ]
}
